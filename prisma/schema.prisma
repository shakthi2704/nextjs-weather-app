// ─────────────────────────────────────────────
//  Prisma Schema — Weather App
// ─────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Users ─────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?   // hashed with bcrypt
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  searches      SearchHistory[]
  settings      UserSettings?

  @@map("users")
}

// ── NextAuth Adapter Models ───────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Favorite Locations ────────────────────────
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  cityName  String
  country   String
  lat       Float
  lon       Float
  timezone  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lat, lon])
  @@map("favorites")
}

// ── Search History ────────────────────────────
model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  query     String
  cityName  String
  country   String
  lat       Float
  lon       Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("search_history")
}

// ── User Settings ─────────────────────────────
model UserSettings {
  id           String  @id @default(cuid())
  userId       String  @unique
  tempUnit     String  @default("C")       // "C" | "F"
  windUnit     String  @default("kmh")     // "kmh" | "mph" | "ms"
  theme        String  @default("dark")    // "dark" | "light" | "system"
  language     String  @default("en")
  defaultLat   Float?
  defaultLon   Float?
  defaultCity  String?
  notifications Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}